@prefix dnb: <https://dnb-harness.local/ontology#> .
@prefix data: <https://dnb-harness.local/data#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dnb:FundShape a sh:NodeShape ;
    sh:targetClass dnb:Fund ;
    sh:property [
        sh:path dnb:fund_name ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Fund must include fund_name raw_text."@en
    ] ;
    sh:property [
        sh:path dnb:has_party ;
        sh:minCount 1 ;
        sh:class dnb:Party ;
        sh:message "Fund must link to Party."@en
    ] ;
    sh:property [
        sh:path dnb:has_fee_schedule ;
        sh:minCount 1 ;
        sh:class dnb:FeeSchedule ;
        sh:message "Fund must link to FeeSchedule."@en
    ] ;
    sh:property [
        sh:path dnb:has_redemption_terms ;
        sh:minCount 1 ;
        sh:class dnb:RedemptionTerms ;
        sh:message "Fund must link to RedemptionTerms."@en
    ] ;
    sh:sparql [
        sh:message "maturity_date must be after inception_date."@en ;
        sh:select """
            PREFIX dnb: <https://dnb-harness.local/ontology#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

            SELECT $this ?inception ?maturity
            WHERE {
                $this dnb:inception_date ?inception ;
                      dnb:maturity_date ?maturity .
                BIND(STR(?inception) AS ?inception_raw)
                BIND(STR(?maturity) AS ?maturity_raw)
                FILTER(
                    REGEX(?inception_raw, "[0-9]{4}\\\\s*년\\\\s*[0-9]{1,2}\\\\s*월\\\\s*[0-9]{1,2}\\\\s*일")
                    && REGEX(?maturity_raw, "[0-9]{4}\\\\s*년\\\\s*[0-9]{1,2}\\\\s*월\\\\s*[0-9]{1,2}\\\\s*일")
                )
                BIND(xsd:integer(REPLACE(?inception_raw, ".*?([0-9]{4})\\\\s*년.*", "$1")) AS ?inception_y)
                BIND(xsd:integer(REPLACE(?inception_raw, ".*?[0-9]{4}\\\\s*년\\\\s*([0-9]{1,2})\\\\s*월.*", "$1")) AS ?inception_m)
                BIND(xsd:integer(REPLACE(?inception_raw, ".*?[0-9]{4}\\\\s*년\\\\s*[0-9]{1,2}\\\\s*월\\\\s*([0-9]{1,2})\\\\s*일.*", "$1")) AS ?inception_d)
                BIND(xsd:integer(REPLACE(?maturity_raw, ".*?([0-9]{4})\\\\s*년.*", "$1")) AS ?maturity_y)
                BIND(xsd:integer(REPLACE(?maturity_raw, ".*?[0-9]{4}\\\\s*년\\\\s*([0-9]{1,2})\\\\s*월.*", "$1")) AS ?maturity_m)
                BIND(xsd:integer(REPLACE(?maturity_raw, ".*?[0-9]{4}\\\\s*년\\\\s*[0-9]{1,2}\\\\s*월\\\\s*([0-9]{1,2})\\\\s*일.*", "$1")) AS ?maturity_d)
                FILTER(
                    ?maturity_y < ?inception_y
                    || (?maturity_y = ?inception_y && ?maturity_m < ?inception_m)
                    || (?maturity_y = ?inception_y && ?maturity_m = ?inception_m && ?maturity_d <= ?inception_d)
                )
            }
        """
    ] .

dnb:ContractPartyShape a sh:NodeShape ;
    sh:targetNode data:party_contract ;
    sh:property [
        sh:path dnb:asset_manager ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Contract Party must include asset_manager raw_text."@en
    ] ;
    sh:property [
        sh:path dnb:trustee ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Contract Party must include exactly one trustee raw_text."@en
    ] .

dnb:ImPartyShape a sh:NodeShape ;
    sh:targetNode data:party_im ;
    sh:property [
        sh:path dnb:asset_manager ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "IM Party must include asset_manager raw_text."@en
    ] .

dnb:FeeScheduleShape a sh:NodeShape ;
    sh:targetClass dnb:FeeSchedule ;
    sh:property [
        sh:path dnb:management_fee ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "FeeSchedule must include management_fee raw_text."@en
    ] ;
    sh:sparql [
        sh:message "management_fee must be within 0.0% and 5.0%."@en ;
        sh:select """
            PREFIX dnb: <https://dnb-harness.local/ontology#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

            SELECT $this ?value ?percent
            WHERE {
                $this dnb:management_fee ?value .
                BIND(STR(?value) AS ?raw)
                FILTER(
                    REGEX(?raw, "%")
                    || REGEX(?raw, "1[,，]?000\\\\s*분의")
                )
                BIND(
                    IF(
                        REGEX(?raw, "1[,，]?000\\\\s*분의"),
                        xsd:decimal(REPLACE(?raw, ".*1[,，]?000\\\\s*분의\\\\s*([0-9]+(?:\\\\.[0-9]+)?).*", "$1")) / 10,
                        xsd:decimal(REPLACE(?raw, ".*?([0-9]+(?:\\\\.[0-9]+)?)[^0-9.]*%.*", "$1"))
                    )
                    AS ?percent
                )
                FILTER(?percent < 0.0 || ?percent > 5.0)
            }
        """
    ] .
